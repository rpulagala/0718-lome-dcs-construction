# Copy to .env and fill in values. Never commit real secrets.

# --- Database (PostgreSQL) ---
# Local Docker default (see docker-compose.yml; host port 5433 to avoid clashes):
DATABASE_URL="postgresql://dcs:dcs_dev_password@localhost:5433/dcs?schema=public"

# --- Auth.js ---
# Generate: openssl rand -base64 32
AUTH_SECRET=""
AUTH_TRUST_HOST="true"
NEXTAUTH_URL="http://localhost:3000"

# --- App ---
APP_BASE_URL="http://localhost:3000"
COMPANY_TIMEZONE="America/Los_Angeles"

# --- Email ---
# EMAIL_MODE: "log" (dev, prints emails to console + EmailLog) | "resend" (real sends)
EMAIL_MODE="log"
RESEND_API_KEY=""
EMAIL_FROM="DCS Construction <noreply@example.com>"
INTAKE_NOTIFY_EMAILS="intake@example.com"

# --- Object storage (photos) ---
# BLOB_MODE: "local" (dev, stores under .storage/) | "vercel" (Vercel Blob)
BLOB_MODE="local"
BLOB_READ_WRITE_TOKEN=""

# --- Uploads ---
MAX_UPLOAD_FILES="10"
MAX_UPLOAD_MB="10"
